# dependencies
node_modules/
.pnp
.pnp.*

# build output
dist/
*.tsbuildinfo
.next/
out/

# npm lockfiles — this is a pnpm workspace; pnpm-lock.yaml is the source of truth
package-lock.json
**/package-lock.json

# env
.env
.env.*
!.env.example

# pulumi: ignore all stack configs EXCEPT the committed dev/prod + example
**/Pulumi.*.yaml
!**/Pulumi.dev.yaml
!**/Pulumi.prod.yaml
!**/Pulumi.dev.yaml.example

# logs / os
*.log
.DS_Store

# assets/plugins: ignore everything that does NOT contain "selectauto"
assets/plugins/*
!assets/plugins/*selectauto*
